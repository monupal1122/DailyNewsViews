PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/newswebsite?retryWrites=true&w=majority

# Admin Account (Created automatically on first boot)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongPassword123@

# JWT Secret (Use a long random string, min 32 characters)
JWT_SECRET=your_super_secret_jwt_key_minimum_32_characters_long

# Redis (Redis Cloud / Upstash)
REDIS_URL=redis://default:YOUR_REDIS_PASSWORD@your-redis-host:PORT

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email / SMTP (Hostinger Webmail or Gmail)
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USERNAME=your_email@yourdomain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=your_email@yourdomain.com

# Session Secret
SESSION_SECRET=your_random_session_secret_key
